# Platform credential manifest — declares which vault credentials this project needs.
# Run `platform env generate` to create .env from this file.

# LLM APIs
ANTHROPIC_API_KEY=anthropic[orchestrator-primary].key
OPENAI_API_KEY=openai[orchestrator-primary].key

# Database (edit database name as needed)
DATABASE_URL=postgresql://${infrastructure.postgresql.user}:${infrastructure.postgresql.passwords[0].password}@${infrastructure.postgresql.host}:${infrastructure.postgresql.port}/mydb

# Notifications
TELEGRAM_BOT_TOKEN=telegram.bot_token
TELEGRAM_CHAT_ID=telegram.chat_id

# MacStudio
MACSTUDIO_HOST=${infrastructure.macstudio.lan_ip}
