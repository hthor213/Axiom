# Axiom — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ---- Required ----

# PostgreSQL password (used by dashboard + postgresql containers)
POSTGRES_PASSWORD=your-secure-password-here

# Email allowed to log in to the dashboard (Google Sign-In)
ALLOWED_EMAIL=your-email@example.com

# ---- API Keys (needed for adversarial pipeline + model registry) ----

# Anthropic API key (Claude — used as Programmer)
ANTHROPIC_API_KEY=

# Google API key (Gemini — used as Adversary)
GOOGLE_API_KEY=

# OpenAI API key (GPT — used as Arbitrator and Mentor)
OPENAI_API_KEY=

# ---- Optional ----

# Google OAuth Client ID (for dashboard Google Sign-In)
GOOGLE_CLIENT_ID=

# JWT secret for dashboard auth (change from default in production)
JWT_SECRET_KEY=change-me-in-production

# GitHub personal access tokens (comma-separated, for project auto-discovery)
GITHUB_TOKENS=

# Telegram bot for notifications when builds complete
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Git commit hash (set automatically during docker compose build)
# GIT_COMMIT=

# PostgreSQL data directory on host (defaults to ./pg-data)
# PG_DATA_DIR=/path/to/pg-data

# Workspace directory for cloning projects (defaults to ./workspace)
# WORKSPACE_DIR=/path/to/workspace
